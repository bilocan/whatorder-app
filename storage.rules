rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Menu photos are fetched unauthenticated by the bot (WhatsApp/Meta) when
    // sending product images, so they must be publicly readable.
    match /menu-photos/{businessId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && (
        firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid)) ||
        (
          firestore.exists(/databases/(default)/documents/owners/$(request.auth.uid)) &&
          businessId in firestore.get(/databases/(default)/documents/owners/$(request.auth.uid)).data.get(
            'businessIds',
            [firestore.get(/databases/(default)/documents/owners/$(request.auth.uid)).data.get('businessId', '')]
          )
        )
      );
    }
  }
}
