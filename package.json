{
  "name": "whatorder",
  "private": true,
  "workspaces": [
    "backend",
    "dashboard"
  ],
  "scripts": {
    "predev": "node scripts/kill-ngrok.js",
    "dev": "dotenv -e .env -- concurrently -n backend,dashboard,ngrok,stripe -c blue,green,yellow,magenta \"npm run dev --prefix backend\" \"npm run dev --prefix dashboard\" \"node scripts/start-ngrok.js\" \"node scripts/start-stripe-listen.js\"",
    "dev:backend": "npm run dev --prefix backend",
    "dev:dashboard": "npm run dev --prefix dashboard",
    "intent:sandbox": "npm run intent:sandbox --prefix backend --",
    "intent:eval": "npm run intent:eval --prefix backend --",
    "intent:eval:enes": "npm run intent:eval --prefix backend -- --enes",
    "intent:export-menu": "npm run intent:export-menu --prefix backend --",
    "intent:init-restaurant": "npm run intent:init-restaurant --prefix backend --",
    "intent:refresh-corpus": "npm run intent:refresh-corpus --prefix backend --",
    "intent:record": "npm run intent:record --prefix backend --",
    "intent:promote": "npm run intent:promote --prefix backend --",
    "intent:ship": "npm run intent:ship --prefix backend --",
    "intent:harvest": "npm run intent:harvest --prefix backend --"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "dotenv-cli": "^11.0.0",
    "jest": "^30.4.2"
  }
}
