VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=whatorder-at.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=whatorder-at
VITE_FIREBASE_STORAGE_BUCKET=whatorder-at.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_API_URL=                     # Production build only (CI → Cloud Run). Ignored in vite dev; npm run dev always proxies /api to :3000.
VITE_GOOGLE_MAPS_API_KEY=         # Maps JavaScript API — Admin → Map + /map. Enable API in GCP; restrict by HTTP referrer.
VITE_WHATSAPP_PHONE_NUMBER_ID=   # Meta phone_number_id — scopes orders/income to this WhatsApp line (test vs prod on shared Firestore)
VITE_WHATSAPP_RETURN_PHONE=     # Optional — human-readable bot number; auto-saved to phoneRouting.displayNumber for the env phone ID
# Injected by CI on deploy (optional for local dev):
VITE_DEPLOY_ENV=                # local | test | preproduction | production
VITE_GIT_SHA=                   # Git commit SHA (short display uses first 7 chars)
VITE_APP_VERSION=               # Release tag (prod) or dev-<sha> (test)
