# WhatsApp Business API
WHATSAPP_ACCESS_TOKEN=EAAB7Oy4ZC1234567890...
WHATSAPP_PHONE_NUMBER_ID=108374321098765
# Customer-facing bot number for post-payment return link (wa.me). Optional if phoneRouting.displayNumber is set.
WHATSAPP_RETURN_PHONE=+436601234567
# Prefill text when opening /chat (QR on pilot one-pager). Default: Hallo
# Customer marketing QR: ?bid={businessId} → ORDER+{businessId} prefill (shared multitenant number)
# Generic customer QR without bid: ?text=Bestellen → restaurant picker flow
WHATSAPP_CHAT_PREFILL=Hallo
WHATSAPP_VERIFY_TOKEN=my_secret_verify_token_abc123
# Meta App Secret — validates X-Hub-Signature-256 on inbound webhooks (required in production)
WHATSAPP_APP_SECRET=
WHATSAPP_BUSINESS_ACCOUNT_ID=102345678901234

# Firebase / Google Cloud
FIREBASE_PROJECT_ID=whatorder-at
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@whatorder-at.iam.gserviceaccount.com

# Backend
NODE_ENV=development
PORT=3000
BACKEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=info

# AI intent parsing (Tier B hybrid — optional)
AI_INTENT_ENABLED=false
LLM_PROVIDER=google
LLM_MODEL=gemini-2.5-flash-lite
GEMINI_API_KEY=
# OPENAI_API_KEY=sk-...
LLM_TIMEOUT_MS=8000
LLM_RETRY_ATTEMPTS=3
LLM_RETRY_DELAY_MS=1000
LLM_RATE_LIMIT_MS=60000
LLM_DAILY_CALL_CAP=5000
# Max menu rows in menu-constrained LLM prompt (default 100)
LLM_MENU_MAX_ITEMS=100

# Stripe (Phase 2a.1 — card checkout, test mode)
# Get keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Payout batch: mock (default) skips stripe.transfers.create; live requires Connect onboarding per restaurant
PAYOUT_CONNECT_MODE=mock
# Cloud Run only — Dashboard webhook signing secret for https://…run.app/webhooks/stripe
# Local `npm run dev` starts stripe listen automatically; secret is written to .stripe-listen-secret (gitignored).
# Optional override here for manual stripe listen. Set STRIPE_DEV_LISTEN=false to skip the CLI in npm run dev.
STRIPE_WEBHOOK_SECRET=
WHATSAPP_RETURN_PHONE=

# Google Maps Platform (pilot — distance + geocoding)
# Enable Distance Matrix API + Geocoding API on the GCP project; restrict key to Cloud Run + dashboard referrer.
# Google Maps Platform (pilot — distance, geocoding, static map preview)
GOOGLE_MAPS_API_KEY=
# Max driving/Haversine distance for restaurant picker + map when customer shares location (km)
RESTAURANT_PICKER_MAX_KM=20

# Public customer map URL for WhatsApp Open map CTA (default prod: https://whatorder.at)
MAP_PUBLIC_URL=