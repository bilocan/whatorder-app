{
  "buildCommand": "npm install --include=dev --prefix dashboard && npm run build --prefix dashboard",
  "outputDirectory": "dashboard/dist",
  "rewrites": [
    { "source": "/webhooks/:path*", "destination": "/api/index" },
    { "source": "/health", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
