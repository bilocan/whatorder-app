{
  "buildCommand": "cd dashboard && npm install --include=dev && npm run build",
  "outputDirectory": "dashboard/dist",
  "rewrites": [
    { "source": "/webhooks/whatsapp", "destination": "/api/webhooks/whatsapp" },
    { "source": "/health", "destination": "/api/index" },
    { "source": "/admin/owners", "destination": "/api/admin/owners" },
    { "source": "/businesses/:businessId/orders/:orderId/ready", "destination": "/api/businesses/:businessId/orders/:orderId/ready" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
